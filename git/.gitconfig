##################################### DEFAULT #####################################
[core]
	editor = emacs -nw
	autocrlf = input
[color]
	diff = auto
	status = auto
	branch = auto
	interactive = auto
	ui = auto
[push]
	default = matching
[rebase]
	autoSquash = true
	autoStash = false
[pull]
	rebase = false
[fetch]
	prune = false
##################################### END OF DEFAULT ##############################